# =============================================================================
# DEVELOPMENT (local)
# =============================================================================
# APP_ENV=local
# APP_DEBUG=true
# APP_URL=http://localhost:8000

# =============================================================================
# PRODUCTION
# =============================================================================
# APP_ENV=production
# APP_DEBUG=false
# APP_URL is the backend/API origin.
# FRONTEND_URL is the browser-facing web origin used in email links and redirects.
# APP_URL=https://dateusher.org
# FRONTEND_URL=https://dateusher.com
# LOG_LEVEL=warning
# MAIL_MAILER=smtp
# (set MAIL_HOST, MAIL_USERNAME, MAIL_PASSWORD, MAIL_FROM_ADDRESS for production)

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Real-time: set BROADCAST_CONNECTION=pusher and PUSHER_* to match mobile Echo config
# Pusher is NOT used for OTP; OTP is sent by email (see MAIL_* below).
BROADCAST_CONNECTION=log
# BROADCAST_CONNECTION=pusher
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_APP_CLUSTER=eu
# PUSHER_SCHEME=https
# PUSHER_HOST=
# PUSHER_PORT=443

# Frontend builds need the public Pusher values too. Do not expose PUSHER_APP_SECRET.
# VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
# VITE_PUSHER_HOST="ws-${PUSHER_APP_CLUSTER}.pusher.com"
# VITE_PUSHER_PORT=443
# VITE_PUSHER_SCHEME=https
# VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Production queue option once Redis is installed on Forge:
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# OTP for registration is sent via email. Use log in dev (code appears in storage/logs/laravel.log).
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@dateusher.com"
MAIL_FROM_NAME="${APP_NAME}"
ADMIN_EMAIL="hello@dateusher.com"
CONTACT_EMAIL="hello@dateusher.com"
# Use an absolute HTTPS URL in production so email clients can load the logo.
MAIL_LOGO_URL=

# Seeded/admin review account. Keep OTP bypass false except while an app reviewer needs access.
ADMIN_SEED_EMAIL="tayojegede1981@gmail.com"
ADMIN_REVIEW_OTP_BYPASS=false
ADMIN_REVIEW_OTP_BYPASS_EMAIL="tayojegede1981@gmail.com"
# Local/demo only. Keep false in production.
SEED_DEMO_DATA=false

# Local-only API documentation route. Keep false or unset in production.
SCRIBE_ADD_ROUTES=false

# Production outbound email: Namecheap Private Email / PrivateEmail.com
# Copy this block to .env and set MAIL_PASSWORD to the mailbox password.
# Port 465 uses SSL via MAIL_SCHEME=smtps in this Laravel mail config.
# MAIL_MAILER=smtp
# MAIL_SCHEME=smtps
# MAIL_HOST=mail.privateemail.com
# MAIL_PORT=465
# MAIL_USERNAME=hello@dateusher.com
# MAIL_PASSWORD=
# MAIL_FROM_ADDRESS="hello@dateusher.com"
# MAIL_FROM_NAME="DateUsher"
# ADMIN_EMAIL="hello@dateusher.com"
# CONTACT_EMAIL="hello@dateusher.com"

# Production inbound email: used later to import client replies into admin contact threads.
# SMTP above sends outbound mail; IMAP below reads replies from the mailbox.
# INBOUND_MAIL_ENABLED=false
# INBOUND_MAIL_DRIVER=imap
# INBOUND_MAIL_HOST=mail.privateemail.com
# INBOUND_MAIL_PORT=993
# INBOUND_MAIL_ENCRYPTION=ssl
# INBOUND_MAIL_USERNAME=hello@dateusher.com
# INBOUND_MAIL_PASSWORD=
# INBOUND_MAIL_MAILBOX=INBOX
# INBOUND_MAIL_SEARCH=UNSEEN
# INBOUND_MAIL_LIMIT=25
# INBOUND_MAIL_MARK_SEEN=false

# SMS OTP: when set, "mobile" channel sends via Twilio. Get from https://console.twilio.com
# TWILIO_SID=
# TWILIO_TOKEN=
# TWILIO_FROM=+15551234567

# Mobile app version prompts. Bump latest for optional updates; bump minimum to force old builds to update.
MOBILE_IOS_LATEST_VERSION=1.0.0
MOBILE_IOS_MINIMUM_SUPPORTED_VERSION=1.0.0
MOBILE_IOS_LATEST_BUILD=
MOBILE_ANDROID_LATEST_VERSION=1.0.0
MOBILE_ANDROID_MINIMUM_SUPPORTED_VERSION=1.0.0
MOBILE_ANDROID_LATEST_BUILD=
MOBILE_UPDATE_MESSAGE="A newer DateUsher app version is available. Update for the latest safety, purchase, and performance improvements."
# Separate release notes with |
MOBILE_RELEASE_NOTES=
IOS_APP_STORE_URL=https://dateusher.com
ANDROID_PLAY_STORE_URL=https://dateusher.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
# Public URL for S3 (required for media URLs). Example: https://your-bucket.s3.region.amazonaws.com
AWS_URL=

AWS_USE_PATH_STYLE_ENDPOINT=false

# Rekognition moderation (image/video on S3). Set false locally if you have no IAM Rekognition rights.
# AWS_REKOGNITION_ENABLED=true
# AWS_REKOGNITION_MIN_CONFIDENCE=60
# AWS_REKOGNITION_FLAG_MIN_CONFIDENCE=75
# AWS_REKOGNITION_VIDEO_POLL_MAX=80
# AWS_REKOGNITION_VIDEO_POLL_DELAY=15

# ImageKit (optional). Leave USE_IMAGEKIT=false to use S3 URLs directly; no ImageKit setup needed.
# USE_IMAGEKIT=false
# IMAGEKIT_URL_ENDPOINT=
# IMAGEKIT_PRIVATE_KEY=
# IMAGEKIT_PUBLIC_KEY=

VITE_APP_NAME="${APP_NAME}"
