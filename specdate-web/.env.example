# App (from Laravel .env – only VITE_* are exposed to the browser)
VITE_APP_NAME=dateusher

# API base URL (used when not using Vite proxy; e.g. production).
# Production should point to the Laravel/API backend, not the public frontend.
# Example: VITE_API_URL=https://dateusher.org
# Leave empty in dev to use the Vite proxy (recommended).
VITE_API_URL=

# Dev-only Vite proxy target. docker-compose exposes Laravel on 8001.
VITE_API_PROXY_TARGET=http://localhost:8001

# Pusher (optional – for realtime; from Laravel .env)
# Do not add PUSHER_APP_SECRET to the web env.
# VITE_PUSHER_APP_KEY=
# VITE_PUSHER_HOST=ws-eu.pusher.com
# VITE_PUSHER_PORT=443
# VITE_PUSHER_SCHEME=https
# VITE_PUSHER_APP_CLUSTER=eu
