# API URLs - app uses _DEV when running in dev, _PRODUCTION when built for release.
# Optional: EXPO_PUBLIC_API_URL is used if the env-specific one is not set.
EXPO_PUBLIC_API_URL_DEV=http://192.168.1.5:8001
EXPO_PUBLIC_API_URL_PRODUCTION=https://dateusher.org

# RevenueCat public SDK keys. These are public client keys, not secret API keys.
# Local Expo/dev testing       -> EXPO_PUBLIC_REVENUECAT_TEST_API_KEY=test_...
# TestFlight iOS testing       -> EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_...
# Google Play internal testing -> EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_...
# App Review / production      -> appl_... / goog_...
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=

# Pusher (real-time) - public key and cluster only. Do not add PUSHER_APP_SECRET.
EXPO_PUBLIC_PUSHER_APP_KEY=
EXPO_PUBLIC_PUSHER_APP_CLUSTER=eu
